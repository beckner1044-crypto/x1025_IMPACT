# Copy this file to .env and fill in the variables for the provider you want.
# The chatbot reads LLM_PROVIDER and the matching key. Only one provider is
# active at a time; the others can stay unset.

# --- Pick one provider --------------------------------------------------------
# local     Mistral-7B on your GPU. No API key needed.
# groq      Free tier, 14,400 req/day, 30 RPM. Recommended for IMPACT demo.
# github    Free, prototyping only per TOS. Lower limits than Groq.
# anthropic Paid Claude API. Recommended for the eval-judge upgrade.
LLM_PROVIDER=groq

# --- Groq Cloud ---------------------------------------------------------------
# Sign up free at https://console.groq.com  (no credit card required)
GROQ_API_KEY=

# --- GitHub Models ------------------------------------------------------------
# Use a fine-grained PAT with the "models" scope.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Anthropic ----------------------------------------------------------------
# Pay-as-you-go account at https://console.anthropic.com
ANTHROPIC_API_KEY=
